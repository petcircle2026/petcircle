# === PetCircle Backend — Environment Variables ===
# Copy this file to .env.development / .env.test and fill in values.
# In production, set these directly in your hosting provider.

# === Environment ===
APP_ENV=development

# === OpenAI ===
OPENAI_API_KEY=sk-your-openai-api-key

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET_NAME=petcircle-documents

# === WhatsApp Cloud API ===
WHATSAPP_TOKEN=your-whatsapp-bearer-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# === WhatsApp Template Names ===
WHATSAPP_TEMPLATE_REMINDER=petcircle_reminder_v1
WHATSAPP_TEMPLATE_OVERDUE=petcircle_overdue_v1
WHATSAPP_TEMPLATE_NUDGE=petcircle_nudge_v1
WHATSAPP_TEMPLATE_CONFLICT=petcircle_conflict_v1
WHATSAPP_TEMPLATE_ONBOARDING_COMPLETE=petcircle_onboarding_complete_v1
WHATSAPP_TEMPLATE_ORDER_FULFILLMENT_CHECK=order_fulfillment_check_v1
WHATSAPP_TEMPLATE_BIRTHDAY=birthday_celebration_v1

# === Admin ===
ADMIN_SECRET_KEY=your-128-bit-hex-admin-secret
ADMIN_DASHBOARD_PASSWORD=your-dashboard-password

# === Database ===
DATABASE_URL=postgresql://user:password@host:port/dbname

# === Security ===
# Fernet encryption key for PII field-level encryption.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key

# Frontend URL for CORS (e.g., https://petcircle.vercel.app)
FRONTEND_URL=http://localhost:3000
