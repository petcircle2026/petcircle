# === PetCircle Backend — Staging Environment ===
# Placeholder values for local testing of staging config.
# Real secrets are injected by Render dashboard.

APP_ENV=staging

# === OpenAI (placeholder — set real key in Render dashboard) ===
OPENAI_API_KEY=sk-staging-placeholder-set-in-render

# === Supabase (staging project — set real values in Render dashboard) ===
SUPABASE_URL=https://staging-project.supabase.co
SUPABASE_KEY=staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=staging-service-role-key
SUPABASE_BUCKET_NAME=petcircle-documents-staging

# === WhatsApp Cloud API (placeholder — set real values in Render dashboard) ===
WHATSAPP_TOKEN=staging-whatsapp-token
WHATSAPP_VERIFY_TOKEN=staging-verify-token
WHATSAPP_PHONE_NUMBER_ID=staging-phone-id
WHATSAPP_APP_SECRET=staging-app-secret

# === WhatsApp Template Names ===
WHATSAPP_TEMPLATE_REMINDER=petcircle_reminder_v1
WHATSAPP_TEMPLATE_OVERDUE=petcircle_overdue_v1
WHATSAPP_TEMPLATE_NUDGE=petcircle_nudge_v1
WHATSAPP_TEMPLATE_CONFLICT=petcircle_conflict_v1
WHATSAPP_TEMPLATE_ONBOARDING_COMPLETE=petcircle_onboarding_complete_v1

# === Admin ===
ADMIN_SECRET_KEY=staging-admin-secret-key

# === Database (staging DB — separate from dev and prod) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petcircle_staging

# === Security ===
# Staging Fernet key (valid base64-encoded 32-byte key for staging use only)
ENCRYPTION_KEY=Khep_Q2La21mid868KZbtr5VR26SEKW4tcfWFEWNiq4=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
